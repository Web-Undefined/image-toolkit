---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Contact — Image Toolkit" description="Get in touch with Image Toolkit. Questions, feedback, or bug reports welcome.">
  <div class="max-w-2xl mx-auto px-6 py-12">
    <h1 class="gradient-text text-3xl font-extrabold tracking-tight mb-6">Contact</h1>
    <div class="space-y-4 text-sm leading-relaxed">
      <p class="text-slate-400">
        Have a question, a bug to report, or a suggestion for a new tool? We'd love to hear from you.
      </p>
      <p class="text-slate-400">
        Email us at
        <a href="mailto:webundefinedcompany@gmail.com" class="text-violet-300 font-semibold hover:text-violet-200 transition-colors">webundefinedcompany@gmail.com</a>
        and we'll get back to you as soon as we can.
      </p>
    </div>
  </div>
</BaseLayout>
